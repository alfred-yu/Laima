# Laima 后端配置

# 服务配置
LAIMA_HTTP_PORT=8080
GIN_MODE=debug

# 数据库配置
LAIMA_DB_HOST=localhost
LAIMA_DB_PORT=5432
LAIMA_DB_NAME=laima
LAIMA_DB_USER=laima
LAIMA_DB_PASSWORD=laima123

# Redis 配置
LAIMA_REDIS_URL=redis://localhost:6379

# MinIO 配置
LAIMA_MINIO_ENDPOINT=localhost:9000
LAIMA_MINIO_ACCESS_KEY=laima
LAIMA_MINIO_SECRET_KEY=laima123
LAIMA_MINIO_USE_SSL=false

# Meilisearch 配置
LAIMA_MEILISEARCH_URL=http://localhost:7700
LAIMA_MEILISEARCH_API_KEY=laima_master_key

# JWT 配置
JWT_SECRET_KEY=laima-secret-key-change-in-production
JWT_EXPIRY_HOURS=168
